---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Book a Free Strategy Call | Basil Metrics Bangkok"
  description="Ready to grow your Bangkok F&B brand? Book a free strategy call with Basil Metrics. Meta, TikTok & Google ads specialists."
>
<div style="background:#F6FBF0;min-height:100vh;">
  <div style="max-width:1200px;margin:0 auto;padding:4rem 1.25rem 7rem;">
    <div style="border-bottom:1px solid rgba(38,53,25,0.08);padding-bottom:2.5rem;margin-bottom:3rem;" class="fade-up">
      <span class="section-label">Get in Touch</span>
      <h1 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,4vw,3.25rem);font-weight:800;color:#263519;letter-spacing:-0.02em;margin:0.5rem 0 0;">Start a Campaign</h1>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;" class="contact-grid">
      <form id="contact-form" action="https://formspree.io/f/mnjozndj" method="POST">
        {[
          { label: 'Your Name',  name: 'name',    type: 'text',  ph: 'e.g. Nong Apinya' },
          { label: 'Company',    name: 'company',  type: 'text',  ph: 'e.g. Your Brand Name' },
          { label: 'Email',      name: 'email',    type: 'email', ph: 'you@yourbrand.com' },
        ].map(f => (
          <div style="margin-bottom:1.25rem;">
            <label class="form-label">{f.label}</label>
            <input type={f.type} name={f.name} required placeholder={f.ph} class="form-input"
              onfocus="this.style.borderColor='#89F337';this.style.boxShadow='0 0 0 3px rgba(137,243,54,0.15)'"
              onblur="this.style.borderColor='rgba(38,53,25,0.14)';this.style.boxShadow='none'" />
          </div>
        ))}
        <div style="margin-bottom:1.25rem;">
          <label class="form-label">Service Interest</label>
          <select name="service" required class="form-input" style="cursor:pointer;"
            onfocus="this.style.borderColor='#89F337'"
            onblur="this.style.borderColor='rgba(38,53,25,0.14)'">
            <option value="" disabled selected>Select a service...</option>
            <option value="Branding">Brand Identity</option>
            <option value="Ads">Performance Ads</option>
            <option value="Both">Brand Identity + Ads</option>
          </select>
        </div>
        <div style="margin-bottom:1.75rem;">
          <label class="form-label">Message</label>
          <textarea name="message" required rows="5"
            placeholder="Tell us about your brand, goals, and monthly budget..."
            class="form-input" style="resize:none;"
            onfocus="this.style.borderColor='#89F337';this.style.boxShadow='0 0 0 3px rgba(137,243,54,0.15)'"
            onblur="this.style.borderColor='rgba(38,53,25,0.14)';this.style.boxShadow='none'"></textarea>
        </div>
        <button type="submit" id="submit-btn" class="btn-lime"
          style="width:100%;text-align:center;font-size:0.9rem;border:none;cursor:pointer;">
          Send Brief →
        </button>
        <div id="form-success" style="display:none;margin-top:1rem;padding:1rem;border:1px solid rgba(137,243,54,0.35);background:rgba(137,243,54,0.07);">
          <p style="font-family:'Sora',sans-serif;font-size:0.85rem;color:#263519;">Message sent — we'll be in touch within 24 hours.</p>
        </div>
        <div id="form-error" style="display:none;margin-top:1rem;padding:1rem;border:1px solid rgba(200,0,0,0.2);background:rgba(200,0,0,0.03);">
          <p style="font-family:'Sora',sans-serif;font-size:0.85rem;color:#cc0000;">Something went wrong. Please try again.</p>
        </div>
      </form>
      <div style="display:flex;flex-direction:column;gap:1.25rem;">
        <div class="card" style="padding:1.75rem;">
          <p class="section-label">Response Time</p>
          <p style="font-family:'Sora',sans-serif;font-size:0.85rem;color:#82976E;line-height:1.65;">We respond to all briefs within 24 hours. For urgent requests, message us directly on LINE.</p>
        </div>
        <div class="card" style="padding:1.75rem;">
          <p class="section-label">We Work With</p>
          <div style="display:flex;flex-direction:column;gap:0.55rem;">
            {[
              'Food startups (pre-launch to Series A)',
              'Delivery-first and cloud kitchen brands',
              'Dine-in restaurants and café groups',
              'Specialty beverage brands',
              'F&B franchise operations',
              'FMCG food products',
            ].map(item => (
              <p style="font-family:'Sora',sans-serif;font-size:0.85rem;color:#82976E;line-height:1.5;">→ {item}</p>
            ))}
          </div>
        </div>
        <div class="card" style="padding:1.75rem;">
          <p class="section-label">Location</p>
          <p style="font-family:'Sora',sans-serif;font-size:0.85rem;color:#82976E;line-height:1.65;">
            Bangkok, Thailand.<br />
            Remote-first. Working with clients across Southeast Asia.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr !important; gap: 2.5rem !important; }
  }
</style>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const btn     = document.getElementById('submit-btn') as HTMLButtonElement;
  const success = document.getElementById('form-success');
  const error   = document.getElementById('form-error');
  form.addEventListener('submit', async e => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending...';
    try {
      const r = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' },
      });
      if (r.ok) {
        form.reset();
        if (success) success.style.display = 'block';
        btn.textContent = 'Sent ✓';
      } else throw new Error();
    } catch {
      if (error) error.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Send Brief →';
    }
  });
</script>
</BaseLayout>
