---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const cmsEntries = await getCollection('portfolio');
  
  const hardcoded = [
    {
      params: { slug: 'meta-fb-high-volume' },
      props: {
        isCMS: false,
        category: 'Dessert & F&B Brand',
        platform: 'Meta',
        label: 'Beating the Feed: High-Volume Meta Traffic',
        result: '14,399 direct visits at just ฿0.62 per click',
        img: 'https://images.unsplash.com/photo-1587314168485-3236d6710814?w=1200&q=80',
        body: `<h2>The Challenge</h2><p>In a saturated F&B market, every baht of ad spend needs to work harder than the last. Our client needed to drive high-volume, qualified traffic directly to their profile and LINE channel without burning through budget on low-intent audiences.</p><h2>The Approach</h2><p>We built a tightly structured Meta campaign targeting Bangkok audiences with demonstrated interest in desserts and premium F&B. Creative was built around high-contrast visual hooks designed to stop the scroll, with clear CTAs driving directly to LINE and profile visits.</p><h2>The Result</h2><p>From approximately ฿8,935 in total ad spend, the campaign generated 14,399 direct profile and LINE visits — a 3.82% Click-Through Rate with a cost of just ฿0.62 per click.</p><h2>Why This Matters</h2><p>According to WordStream, the average Meta Ads Cost Per Lead for F&B is ~฿110. We delivered at ฿0.62 — approximately 6% of the standard market rate.</p>`,
        benchmarkSource: 'WordStream Meta Ads Benchmarks for Restaurant & Food industry',
        benchmarkUrl: 'https://www.wordstream.com/blog/ws/2021/09/15/facebook-ads-benchmarks',
      },
    },
    {
      params: { slug: 'tiktok-viral-sprint' },
      props: {
        isCMS: false,
        category: 'Dessert & F&B Brand',
        platform: 'TikTok',
        label: 'The Viral Sprint: Rapid TikTok Audience Growth',
        result: '+400 targeted followers in under 18 hours — 547 new followers per day',
        img: 'https://images.unsplash.com/photo-1611162616305-c69b3fa7fbe0?w=1200&q=80',
        body: `<h2>The Challenge</h2><p>The client needed to accelerate their TikTok presence rapidly — not through slow organic growth, but through a strategic sprint that would create immediate momentum toward the critical 100K milestone.</p><h2>The Approach</h2><p>We engineered a high-velocity follower acquisition sprint using targeted content strategy, optimised posting windows, and audience engagement mechanics specific to the Thai F&B TikTok ecosystem.</p><h2>The Result</h2><p>400 new followers acquired in under 18 hours — 547 new followers per day — pushing the account to 94.6K and creating clear trajectory toward 100K.</p><h2>Why This Matters</h2><p>According to Rival IQ, average brand accounts see 2–3% monthly follower growth. This sprint delivered immediate daily momentum that radically outperforms standard brand growth timelines.</p>`,
        benchmarkSource: 'Rival IQ TikTok Benchmark Report',
        benchmarkUrl: 'https://www.rivaliq.com/blog/tiktok-benchmark-report/',
      },
    },
    {
      params: { slug: 'google-retail-search' },
      props: {
        isCMS: false,
        category: 'Premium Retail Brand',
        platform: 'Google',
        label: 'Capturing the Buyer: High-Intent Google Search',
        result: '~1,000 high-intent clicks at ฿4.75 CPC — 4.30% CTR',
        img: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80',
        body: `<h2>The Challenge</h2><p>A premium retail brand needed to capture bottom-of-funnel, ready-to-buy traffic for a specific product line.</p><h2>The Approach</h2><p>We built a tightly structured Google Search campaign targeting high-intent, product-specific keywords. Match types, negative keywords, and bid strategies were layered carefully to eliminate wasted spend.</p><h2>The Result</h2><p>Nearly 1,000 highly qualified clicks at ฿4.75 CPC with a 4.30% Click-Through Rate.</p><h2>Why This Matters</h2><p>WordStream reports the average CPC for retail is ~฿118. We captured high-intent traffic at ฿4.75 — massively undercutting the standard market rate.</p>`,
        benchmarkSource: 'WordStream Google Ads Benchmarks for Apparel/Fashion & Jewelry',
        benchmarkUrl: 'https://www.wordstream.com/blog/ws/2016/02/29/google-adwords-industry-benchmarks',
      },
    },
  ];

  const cmsRoutes = cmsEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { isCMS: true, entry },
  }));

  return [...hardcoded, ...cmsRoutes];
}

const { isCMS, entry, category, platform, label, result, img, body, benchmarkSource, benchmarkUrl } = Astro.props;
const { Content } = isCMS && entry ? await entry.render() : { Content: null };

let CmsContent: any = null;
if (isCMS && entry) {
  const { Content } = await entry.render();
  CmsContent = Content;
}
---

<BaseLayout
  title={isCMS ? `${entry?.data.client_name} — Portfolio — Basil Metrics` : `${label} — Portfolio — Basil Metrics`}
  description={isCMS ? entry?.data.result : result}
>
<div style="background:#F6FBF0;min-height:100vh;">
  <div style="max-width:900px;margin:0 auto;padding:4rem 1.25rem 7rem;">

    <a href="/portfolio" style="font-family:'Sora',sans-serif;font-size:0.8rem;color:#82976E;text-decoration:none;display:inline-block;margin-bottom:2.5rem;">← All Work</a>

    {isCMS && entry ? (
      <>
        <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:1rem;flex-wrap:wrap;">
          <span style="font-family:'Sora',sans-serif;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:#82976E;font-weight:600;">{entry.data.category}</span>
          <span style="font-family:'Sora',sans-serif;font-size:0.6rem;background:rgba(137,243,54,0.15);color:#263519;border-radius:99px;padding:0.18rem 0.65rem;font-weight:600;">{entry.data.platform}</span>
        </div>
        <p style="font-family:'Sora',sans-serif;font-size:0.7rem;color:#82976E;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.75rem;">{entry.data.client_name}</p>
        <h1 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3.5vw,2.75rem);font-weight:800;color:#263519;line-height:1.12;letter-spacing:-0.02em;margin-bottom:2.5rem;">{entry.data.result}</h1>
        {entry.data.cover_image && (
          <div style="margin-bottom:3rem;overflow:hidden;border:1px solid rgba(38,53,25,0.08);">
            <img src={entry.data.cover_image} alt={entry.data.client_name} style="width:100%;object-fit:cover;display:block;" loading="eager" />
          </div>
        )}
        <div class="prose" <Content /> />
      </>
    ) : (
      <>
        <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:1rem;flex-wrap:wrap;">
          <span style="font-family:'Sora',sans-serif;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:#82976E;font-weight:600;">{category}</span>
          <span style="font-family:'Sora',sans-serif;font-size:0.6rem;background:rgba(137,243,54,0.15);color:#263519;border-radius:99px;padding:0.18rem 0.65rem;font-weight:600;">{platform}</span>
        </div>
        <p style="font-family:'Sora',sans-serif;font-size:0.7rem;color:#82976E;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.75rem;">{label}</p>
        <h1 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3.5vw,2.75rem);font-weight:800;color:#263519;line-height:1.12;letter-spacing:-0.02em;margin-bottom:2.5rem;">{result}</h1>
        <div style="margin-bottom:3rem;overflow:hidden;border:1px solid rgba(38,53,25,0.08);">
          <img src={img} alt={label} style="width:100%;object-fit:cover;display:block;" loading="eager" />
        </div>
        <div class="prose" set:html={body} />
        <div style="margin-top:2.5rem;padding:1.25rem 1.5rem;background:rgba(38,53,25,0.03);border:1px solid rgba(38,53,25,0.08);border-left:2px solid #89F337;">
          <p style="font-family:'Sora',sans-serif;font-size:0.78rem;color:#82976E;line-height:1.6;">
            <strong style="color:#263519;">Benchmark source:</strong> {benchmarkSource}.
            <a href={benchmarkUrl} target="_blank" rel="noopener noreferrer" style="color:#263519;text-decoration:underline;text-underline-offset:3px;margin-left:0.25rem;">View source →</a>
          </p>
        </div>
      </>
    )}

    <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(38,53,25,0.08);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;">
      <a href="/portfolio" style="font-family:'Sora',sans-serif;font-size:0.8rem;color:#82976E;text-decoration:none;">← All Work</a>
      <a href="/contact" class="btn-lime" style="font-size:0.82rem;padding:0.7rem 1.5rem;">Start a Similar Campaign</a>
    </div>

  </div>
</div>
</BaseLayout>
