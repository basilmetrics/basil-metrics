</section>

<style>
  @keyframes pulse-dot  { 0%,100%{box-shadow:0 0 8px #89F337} 50%{box-shadow:0 0 3px #89F337} }
  @keyframes curtain-up { from{transform:translateY(0)} to{transform:translateY(-100%)} }
  @keyframes scan-sweep { 0%{top:0;opacity:0} 3%{opacity:1} 97%{opacity:1} 100%{top:100%;opacity:0} }
  #page-curtain.out     { animation: curtain-up 0.65s cubic-bezier(0.76,0,0.24,1) forwards; }
  #scan-line.scanning   { animation: scan-sweep 1.8s ease-in-out forwards; }
  .platform-card { transition:background 0.18s,transform 0.18s; }
  .platform-card:hover  { background:#F6FBF0 !important; transform:translateY(-2px); }
  @media (max-width:768px) {
    .platforms-grid,.process-grid { grid-template-columns:1fr 1fr !important; }
    .results-grid,.strip-grid     { grid-template-columns:1fr !important; }
    .chart-stats-grid              { grid-template-columns:1fr !important; }
    .ads-stats                     { flex-direction:column !important; }
    .ads-stats > div { border-right:none !important; border-bottom:1px solid rgba(137,243,55,0.15) !important; }
    .ads-stats > div:last-child    { border-bottom:none !important; }
  }
  @media (prefers-reduced-motion:reduce) { #page-curtain{display:none;} }
</style>

<script>
// ── Curtain ──────────────────────────────────────────────
const curtain = document.getElementById('page-curtain');
if (curtain) requestAnimationFrame(() => setTimeout(() => curtain.classList.add('out'), 60));

// ── Dot grid ─────────────────────────────────────────────
function initDotGrid() {
  const canvas = document.getElementById('dot-grid');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const S = 36;
  let mx = -999, my = -999;
  function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight; }
  resize();
  window.addEventListener('resize', resize);
  const sec = canvas.closest('section');
  sec.addEventListener('mousemove', e => { const r=canvas.getBoundingClientRect(); mx=e.clientX-r.left; my=e.clientY-r.top; });
  sec.addEventListener('mouseleave', () => { mx=-999; my=-999; });
  (function draw() {
    ctx.clearRect(0,0,canvas.width,canvas.height);
    for (let r=0; r<=canvas.height/S+1; r++) for (let c=0; c<=canvas.width/S+1; c++) {
      const x=c*S, y=r*S, d=Math.hypot(x-mx,y-my);
      const g=Math.max(0,1-d/200), sz=1.5+g*6, a=0.15+g*0.85;
      ctx.beginPath(); ctx.arc(x,y,sz,0,Math.PI*2);
      ctx.shadowColor='#89F337'; ctx.shadowBlur=g*20;
      ctx.fillStyle=`rgba(137,243,55,${a})`; ctx.fill();
    }
    ctx.shadowBlur=0;
    requestAnimationFrame(draw);
  })();
}

// ── Counting stats ───────────────────────────────────────
function runCount() {
  const scan=document.getElementById('scan-line');
  if(scan){scan.classList.remove('scanning');void scan.offsetWidth;scan.classList.add('scanning');}
  const sg=document.getElementById('stat-glow');
  if(sg){sg.style.transform='translateX(-100%)';requestAnimationFrame(()=>{sg.style.transform='translateX(200%)';})}
  const items=[
    {id:'a-cpc',  to:0.62,  p:'฿',s:'',  d:2},
    {id:'a-reach',to:14399, p:'', s:'',  d:0},
    {id:'a-ctr',  to:3.82,  p:'', s:'%', d:2},
  ];
  const dur=2400, t0=performance.now();
  (function tick(now) {
    const e=1-Math.pow(1-Math.min((now-t0)/dur,1),3);
    items.forEach(({id,to,p,s,d})=>{ const el=document.getElementById(id); if(el) el.textContent=p+(e*to).toFixed(d)+s; });
    if(now-t0<dur) requestAnimationFrame(tick);
  })(performance.now());
}

// ── Dynamic chart ─────────────────────────────────────────
const CHARTS = {
  cpc: {
    label:'Cost Per Click (฿) — lower is better',
    basil:   [0.90,0.78,0.70,0.62,0.58,0.60,0.55,0.62],
    industry:[110, 108, 112, 110, 115, 110, 108, 110],
    invert: true,
    yMax: 130,
    fmt: v => '฿'+v.toFixed(2),
  },
  ctr: {
    label:'Click-Through Rate (%) — higher is better',
    basil:   [2.1,2.8,3.2,3.6,3.82,3.7,3.9,3.82],
    industry:[0.8,0.85,0.9,0.88,0.9,0.92,0.89,0.9],
    invert: false,
    yMax: 5,
    fmt: v => v.toFixed(2)+'%',
  },
  followers: {
    label:'Follower Growth (per day) — higher is better',
    basil:   [120,210,310,400,547,480,520,547],
    industry:[15, 18,  20,  22, 25,  23,  21,  25],
    invert: false,
    yMax: 600,
    fmt: v => '+'+Math.round(v),
  },
};
const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug'];
let activeChart = 'cpc';
let rafId = null;

function switchChart(key) {
  activeChart = key;
  ['cpc','ctr','followers'].forEach(k => {
    const btn = document.getElementById('tab-'+k);
    if (!btn) return;
    btn.style.background = k===key ? '#89F337' : 'transparent';
    btn.style.color      = k===key ? '#263519' : '#6a8a5a';
  });
  const lbl = document.getElementById('chart-label');
  if (lbl) lbl.textContent = CHARTS[key].label;
  if (rafId) cancelAnimationFrame(rafId);
  drawChart(key, 0);
}
window.switchChart = switchChart;

function drawChart(key, startProgress) {
  const canvas = document.getElementById('perf-chart');
  if (!canvas) return;
  const dpr = window.devicePixelRatio || 1;
  if (canvas._key !== key) {
    canvas.width  = canvas.offsetWidth  * dpr;
    canvas.height = canvas.offsetHeight * dpr;
    canvas._key   = key;
  }
  const ctx = canvas.getContext('2d');
  ctx.setTransform(dpr,0,0,dpr,0,0);
  const W=canvas.offsetWidth, H=canvas.offsetHeight;
  const pad={top:20,right:20,bottom:32,left:52};
  const cW=W-pad.left-pad.right, cH=H-pad.top-pad.bottom;
  const cfg = CHARTS[key];

  function norm(v) { return cfg.invert ? 1-(v/cfg.yMax) : v/cfg.yMax; }
  function getXY(data,i,f) {
    const idx=Math.min(i,data.length-2);
    const x=pad.left+((idx+(f||0))/(data.length-1))*cW;
    const v=data[idx]+((data[idx+1]||data[idx])-data[idx])*(f||0);
    return {x, y:pad.top+(1-norm(v))*cH, v};
  }

  let progress = startProgress || 0;
  const startTime = performance.now();
  const prevProgress = startProgress || 0;

  function frame(now) {
    progress = Math.min(1, prevProgress + (now-startTime)/1800);
    ctx.clearRect(0,0,W,H);

    // Grid
    for(let i=0;i<=4;i++){
      const y=pad.top+(cH/4)*i;
      ctx.beginPath();ctx.strokeStyle='rgba(137,243,55,0.07)';ctx.lineWidth=1;
      ctx.moveTo(pad.left,y);ctx.lineTo(W-pad.right,y);ctx.stroke();
      const val=cfg.invert ? cfg.yMax-(cfg.yMax/4)*i : (cfg.yMax/4)*i;
      ctx.fillStyle='rgba(137,243,55,0.3)';ctx.font=`9px "Courier New"`;ctx.textAlign='right';
      ctx.fillText(val>=1?Math.round(val):val.toFixed(2), pad.left-6, y+4);
    }
    months.forEach((m,i)=>{
      const x=pad.left+(i/(months.length-1))*cW;
      ctx.fillStyle='rgba(137,243,55,0.3)';ctx.font=`9px "Courier New"`;ctx.textAlign='center';
      ctx.fillText(m,x,H-pad.bottom+18);
    });

    const pts=Math.floor(progress*(months.length-1));
    const frac=progress*(months.length-1)-pts;

    // Industry line
    ctx.beginPath();ctx.strokeStyle='rgba(74,106,58,0.5)';ctx.lineWidth=1.5;ctx.setLineDash([5,5]);
    for(let i=0;i<=pts;i++){const {x,y}=getXY(cfg.industry,i,i===pts?frac:0);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);}
    ctx.stroke();ctx.setLineDash([]);

    // Basil area
    if(pts>=1){
      ctx.beginPath();
      for(let i=0;i<=pts;i++){const {x,y}=getXY(cfg.basil,i,i===pts?frac:0);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);}
      const last=getXY(cfg.basil,pts,frac), first=getXY(cfg.basil,0,0);
      ctx.lineTo(last.x,pad.top+cH);ctx.lineTo(first.x,pad.top+cH);ctx.closePath();
      const gr=ctx.createLinearGradient(0,pad.top,0,pad.top+cH);
      gr.addColorStop(0,'rgba(137,243,55,0.2)');gr.addColorStop(1,'rgba(137,243,55,0)');
      ctx.fillStyle=gr;ctx.fill();
    }

    // Basil line
    ctx.beginPath();ctx.strokeStyle='#89F337';ctx.lineWidth=3;ctx.shadowColor='#89F337';ctx.shadowBlur=14;
    for(let i=0;i<=pts;i++){const {x,y}=getXY(cfg.basil,i,i===pts?frac:0);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);}
    ctx.stroke();ctx.shadowBlur=0;

    // Pulsing tip
    if(progress>0){
      const tip=getXY(cfg.basil,pts,frac);
      const pulse=0.5+0.5*Math.sin(now/180);
      ctx.beginPath();ctx.arc(tip.x,tip.y,5+pulse*4,0,Math.PI*2);
      ctx.fillStyle=`rgba(137,243,55,${0.12+pulse*0.15})`;ctx.fill();
      ctx.beginPath();ctx.arc(tip.x,tip.y,5,0,Math.PI*2);
      ctx.shadowColor='#89F337';ctx.shadowBlur=22;ctx.fillStyle='#89F337';ctx.fill();ctx.shadowBlur=0;
      ctx.fillStyle='#89F337';ctx.font=`bold 10px "Courier New"`;ctx.textAlign='center';
      ctx.fillText(cfg.fmt(tip.v),tip.x,tip.y-14);
    }

    rafId = requestAnimationFrame(frame);
  }
  rafId = requestAnimationFrame(frame);
}

// ── Init ──────────────────────────────────────────────────
function init() {
  initDotGrid();
  // Start chart when section scrolls into view
  const chartSection = document.getElementById('perf-chart');
  if (chartSection) {
    new IntersectionObserver((e,o)=>{
      if(e[0].isIntersecting){ switchChart('cpc'); o.disconnect(); }
    },{threshold:0.3}).observe(chartSection);
  }
  // Count stats when hero visible
  const hero=document.getElementById('ads-hero');
  if(hero) new IntersectionObserver((e,o)=>{ if(e[0].isIntersecting){runCount();o.disconnect();} },{threshold:0.2}).observe(hero);
}
init();
document.addEventListener('astro:page-load', init);
</script>

</BaseLayout>
