      <div class="fade-up" style="background:#fff;padding:2.5rem;"><div style="display:flex;align-items:center;gap:8px;margin-bottom:1.25rem;"><span style="font-family:'Sora',sans-serif;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:#82976E;font-weight:600;">Dessert & F&B</span><span style="font-family:'Sora',sans-serif;font-size:10px;background:rgba(137,243,54,0.15);color:#263519;border-radius:99px;padding:2px 10px;font-weight:600;">TikTok</span></div><p style="font-family:'Sora',sans-serif;font-size:11px;color:#82976E;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;margin:0 0 8px;">The Viral Sprint</p><p style="font-family:'Sora',sans-serif;font-size:2rem;font-weight:800;color:#263519;line-height:1.1;margin:0 0 12px;">+400 in 18 hrs</p><p style="font-family:'Sora',sans-serif;font-size:13px;color:#445538;line-height:1.6;margin:0 0 1.25rem;">547 new followers/day · reached 94.6K · on track for 100K</p><div style="border-top:1px solid rgba(38,53,25,0.07);padding-top:12px;"><p style="font-family:'Sora',sans-serif;font-size:12px;color:#82976E;font-style:italic;margin:0;">Industry avg: 2–3% monthly growth</p></div></div>
      <div class="fade-up" style="background:#fff;padding:2.5rem;"><div style="display:flex;align-items:center;gap:8px;margin-bottom:1.25rem;"><span style="font-family:'Sora',sans-serif;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:#82976E;font-weight:600;">Premium Retail</span><span style="font-family:'Sora',sans-serif;font-size:10px;background:rgba(137,243,54,0.15);color:#263519;border-radius:99px;padding:2px 10px;font-weight:600;">Google</span></div><p style="font-family:'Sora',sans-serif;font-size:11px;color:#82976E;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;margin:0 0 8px;">Capturing the Buyer</p><p style="font-family:'Sora',sans-serif;font-size:2rem;font-weight:800;color:#263519;line-height:1.1;margin:0 0 12px;">฿4.75 per click</p><p style="font-family:'Sora',sans-serif;font-size:13px;color:#445538;line-height:1.6;margin:0 0 1.25rem;">~1,000 high-intent clicks · 4.30% CTR · bottom-of-funnel</p><div style="border-top:1px solid rgba(38,53,25,0.07);padding-top:12px;"><p style="font-family:'Sora',sans-serif;font-size:12px;color:#82976E;font-style:italic;margin:0;">Industry avg: ~฿118 CPC for retail</p></div></div>
    </div>
  </div>
</section>

<!-- STAT STRIP -->
<section style="background:#89F337;padding:3.5rem 0;">
  <div style="max-width:1200px;margin:0 auto;padding:0 48px;box-sizing:border-box;display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;text-align:center;" class="strip-grid">
    <div class="fade-up"><div style="font-family:'Sora',sans-serif;font-size:clamp(2.5rem,5vw,3.5rem);font-weight:800;color:#263519;line-height:1;margin-bottom:6px;">฿0.62</div><div style="font-family:'Sora',sans-serif;font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#263519;opacity:0.65;">Cost per click</div></div>
    <div class="fade-up"><div style="font-family:'Sora',sans-serif;font-size:clamp(2.5rem,5vw,3.5rem);font-weight:800;color:#263519;line-height:1;margin-bottom:6px;">+400</div><div style="font-family:'Sora',sans-serif;font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#263519;opacity:0.65;">Followers in 18 hours</div></div>
    <div class="fade-up"><div style="font-family:'Sora',sans-serif;font-size:clamp(2.5rem,5vw,3.5rem);font-weight:800;color:#263519;line-height:1;margin-bottom:6px;">3.82%</div><div style="font-family:'Sora',sans-serif;font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#263519;opacity:0.65;">Average CTR</div></div>
