<script>
  const targets = [
    { el: document.getElementById('a-cpc'),   to:0.62,  prefix:'฿', suffix:'',  decimals:2 },
    { el: document.getElementById('a-reach'), to:14399, prefix:'',  suffix:'',  decimals:0 },
    { el: document.getElementById('a-ctr'),   to:3.82,  prefix:'',  suffix:'%', decimals:2 },
  ];
  function easeOut(t){ return 1-Math.pow(1-t,3); }
  function runCount(){
    const dur=2200, start=performance.now();
    function tick(now){
      const ease=easeOut(Math.min((now-start)/dur,1));
      targets.forEach(({el,to,prefix,suffix,decimals})=>{ if(el) el.textContent=prefix+(ease*to).toFixed(decimals)+suffix; });
      if((now-start)<dur) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  const hero=document.getElementById('ads-hero');
  if(hero) new IntersectionObserver((e,o)=>{ if(e[0].isIntersecting){runCount();o.disconnect();} },{threshold:0.2}).observe(hero);
  document.addEventListener('astro:page-load',()=>{
    const h=document.getElementById('ads-hero');
    if(h) new IntersectionObserver((e,o)=>{ if(e[0].isIntersecting){runCount();o.disconnect();} },{threshold:0.2}).observe(h);
  });
</script>

