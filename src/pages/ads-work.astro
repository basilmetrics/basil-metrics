</section>

<!-- CTA -->
<section style="background:#F6FBF0;padding:5rem 0;">
  <div style="max-width:680px;margin:0 auto;padding:0 48px;box-sizing:border-box;text-align:center;">
    <div class="fade-up">
      <span style="font-family:'Sora',sans-serif;font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:1rem;">Ready to fix your ads?</span>
      <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.8rem,3.5vw,3rem);font-weight:800;color:#263519;letter-spacing:-0.025em;line-height:1.1;margin:0 0 1.25rem;">Stop wasting ad spend.<br/>Start getting results.</h2>
      <p style="font-family:'Sora',sans-serif;font-size:15px;color:#445538;line-height:1.7;max-width:440px;margin:0 auto 2rem;">Tell us your brand, your platforms, your budget. We'll audit your current setup and show you exactly where the money is going.</p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
        <a href="/contact" style="display:inline-flex;align-items:center;gap:8px;background:#263519;color:#F6FBF0;font-family:'Sora',sans-serif;font-size:14px;font-weight:700;padding:15px 32px;border-radius:3px;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='.82'" onmouseout="this.style.opacity='1'">Get a free audit <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <a href="/portfolio" style="display:inline-flex;align-items:center;gap:8px;color:#263519;font-family:'Sora',sans-serif;font-size:14px;font-weight:500;padding:15px 24px;text-decoration:none;border:1px solid rgba(38,53,25,0.25);border-radius:3px;transition:border-color 0.2s;" onmouseover="this.style.borderColor='#263519'" onmouseout="this.style.borderColor='rgba(38,53,25,0.25)'">View all case studies</a>
