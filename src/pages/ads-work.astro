---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Ads Work — Performance Advertising for Bangkok F&B | Basil Metrics"
  description="Meta, TikTok, Google, Grab and LINE MAN advertising for Bangkok restaurants and F&B brands."
>

<div id="page-curtain" aria-hidden="true" style="position:fixed;inset:0;background:#263519;z-index:9999;pointer-events:none;"></div>

<!-- HERO -->
<section id="ads-hero" transition:name="pillar-ads" style="background:#263519;min-height:100vh;display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden;">
  <canvas id="dot-grid" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;"></canvas>
  <div id="scan-line" aria-hidden="true" style="position:absolute;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,#89F337,transparent);z-index:1;pointer-events:none;top:0;opacity:0;box-shadow:0 0 12px #89F337;"></div>

  <div style="max-width:1200px;margin:0 auto;padding:120px 48px 72px;width:100%;position:relative;z-index:2;box-sizing:border-box;">

    <a href="/" style="display:inline-flex;align-items:center;gap:8px;color:#82976E;font-family:'Sora',sans-serif;font-size:11px;font-weight:500;text-decoration:none;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:0px;transition:color 0.2s;display:block;" onmouseover="this.style.color='#F6FBF0'" onmouseout="this.style.color='#82976E'">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M13 8H3M7 4l-4 4 4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Back to home
    </a>

    <div style="display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(137,243,55,0.35);padding:6px 14px;border-radius:2px;margin-bottom:28px;margin-top:16px;">
      <span style="width:7px;height:7px;border-radius:50%;background:#89F337;display:inline-block;box-shadow:0 0 8px #89F337;animation:pulse-dot 2s ease-in-out infinite;"></span>
      <span style="font-family:'Sora',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:#89F337;">Ads Work — System Active</span>
    </div>

    <h1 style="color:#F6FBF0;font-family:'Sora',sans-serif;font-size:clamp(2.6rem,5.5vw,4.6rem);font-weight:800;line-height:1.06;letter-spacing:-0.03em;max-width:820px;margin:0 0 24px;">
      Ads that make every<br/>
      <span style="color:#89F337;text-shadow:0 0 40px rgba(137,243,55,0.3);">baht work harder.</span>
    </h1>

    <p style="color:#C8DDB8;font-family:'Sora',sans-serif;font-size:clamp(1rem,1.8vw,1.15rem);line-height:1.75;max-width:500px;margin:0 0 48px;">
      Performance advertising across every platform your customers use — built for Bangkok's F&B market, optimised for measurable return.
    </p>

    <div style="display:flex;gap:0;border:1px solid rgba(137,243,55,0.45);max-width:580px;position:relative;overflow:hidden;" class="ads-stats">
      <div id="stat-glow" style="position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(137,243,55,0.07),transparent);transform:translateX(-100%);pointer-events:none;z-index:1;transition:transform 1.2s ease-out;"></div>
      <div style="flex:1;padding:20px 22px;border-right:1px solid rgba(137,243,55,0.15);">
        <div style="font-family:'Courier New',monospace;font-size:9px;color:#A8C898;letter-spacing:0.14em;text-transform:uppercase;margin-bottom:8px;">// cost_per_click</div>
        <div id="a-cpc" style="color:#89F337;font-family:'Courier New',monospace;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;line-height:1;text-shadow:0 0 20px rgba(137,243,55,0.5);">฿0.00</div>
      </div>
      <div style="flex:1;padding:20px 22px;border-right:1px solid rgba(137,243,55,0.15);">
        <div style="font-family:'Courier New',monospace;font-size:9px;color:#A8C898;letter-spacing:0.14em;text-transform:uppercase;margin-bottom:8px;">// profile_visits</div>
        <div id="a-reach" style="color:#89F337;font-family:'Courier New',monospace;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;line-height:1;text-shadow:0 0 20px rgba(137,243,55,0.5);">0</div>
      </div>
      <div style="flex:1;padding:20px 22px;">
        <div style="font-family:'Courier New',monospace;font-size:9px;color:#A8C898;letter-spacing:0.14em;text-transform:uppercase;margin-bottom:8px;">// avg_ctr</div>
        <div id="a-ctr" style="color:#89F337;font-family:'Courier New',monospace;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;line-height:1;text-shadow:0 0 20px rgba(137,243,55,0.5);">0.00%</div>
      </div>
    </div>

    <div style="display:flex;gap:16px;flex-wrap:wrap;margin-top:36px;">
      <a href="/contact" style="display:inline-flex;align-items:center;gap:8px;background:#89F337;color:#263519;font-family:'Sora',sans-serif;font-size:14px;font-weight:700;padding:15px 32px;border-radius:3px;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.boxShadow='0 0 24px rgba(137,243,55,0.45)'" onmouseout="this.style.boxShadow='none'">
        Get a free audit
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="#263519" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="/portfolio" style="display:inline-flex;align-items:center;gap:8px;color:#C8DDB8;font-family:'Sora',sans-serif;font-size:14px;font-weight:500;padding:15px 24px;text-decoration:none;border:1px solid rgba(200,221,184,0.3);border-radius:3px;transition:border-color 0.2s;" onmouseover="this.style.borderColor='rgba(200,221,184,0.7)'" onmouseout="this.style.borderColor='rgba(200,221,184,0.3)'">
        See case studies
      </a>
    </div>
  </div>
</section>

<!-- LIVE CHART -->
<section style="background:#111a0b;padding:4rem 0;border-bottom:1px solid rgba(137,243,55,0.1);">
  <div style="max-width:1200px;margin:0 auto;padding:0 48px;box-sizing:border-box;">

    <div class="fade-up" style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem;">
      <div>
        <span style="font-family:'Courier New',monospace;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:#6a8a5a;display:block;margin-bottom:6px;">// campaign_performance.live</span>
        <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.4rem,2.5vw,1.9rem);font-weight:800;color:#F6FBF0;letter-spacing:-0.02em;margin:0;">What good ad spend looks like.</h2>
      </div>
      <!-- Chart tabs -->
      <div style="display:flex;gap:4px;border:1px solid rgba(137,243,55,0.2);border-radius:3px;overflow:hidden;">
        <button id="tab-cpc" onclick="switchChart('cpc')" style="font-family:'Sora',sans-serif;font-size:12px;font-weight:600;padding:8px 18px;border:none;cursor:pointer;letter-spacing:0.04em;transition:all 0.2s;background:#89F337;color:#263519;">CPC</button>
        <button id="tab-ctr" onclick="switchChart('ctr')" style="font-family:'Sora',sans-serif;font-size:12px;font-weight:600;padding:8px 18px;border:none;cursor:pointer;letter-spacing:0.04em;transition:all 0.2s;background:transparent;color:#6a8a5a;">CTR</button>
        <button id="tab-followers" onclick="switchChart('followers')" style="font-family:'Sora',sans-serif;font-size:12px;font-weight:600;padding:8px 18px;border:none;cursor:pointer;letter-spacing:0.04em;transition:all 0.2s;background:transparent;color:#6a8a5a;">Followers</button>
      </div>
    </div>

    <div style="display:flex;gap:24px;margin-bottom:1rem;align-items:center;">
      <span style="display:flex;align-items:center;gap:8px;font-family:'Sora',sans-serif;font-size:11px;color:#82976E;"><span style="width:24px;height:2px;background:#89F337;display:inline-block;border-radius:1px;box-shadow:0 0 6px #89F337;"></span>Basil Metrics</span>
      <span style="display:flex;align-items:center;gap:8px;font-family:'Sora',sans-serif;font-size:11px;color:#82976E;"><span style="width:24px;height:2px;background:#4a6a3a;display:inline-block;border-radius:1px;opacity:0.7;border-top:1px dashed #4a6a3a;"></span>Industry avg</span>
      <span id="chart-label" style="font-family:'Courier New',monospace;font-size:11px;color:#89F337;margin-left:auto;"></span>
    </div>

    <div style="position:relative;background:rgba(137,243,55,0.02);border:1px solid rgba(137,243,55,0.1);border-radius:4px;padding:20px 16px 8px;">
      <canvas id="perf-chart" style="width:100%;height:200px;display:block;"></canvas>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(137,243,55,0.08);margin-top:1px;" class="chart-stats-grid">
      <div style="padding:1.25rem 1.75rem;background:#111a0b;">
        <div style="font-family:'Courier New',monospace;font-size:9px;color:#6a8a5a;letter-spacing:0.12em;margin-bottom:6px;">COST_PER_CLICK</div>
        <div style="font-family:'Sora',sans-serif;font-size:1.4rem;font-weight:800;color:#89F337;">฿0.62 <span style="font-size:12px;color:#82976E;font-weight:400;">vs ฿110 industry</span></div>
      </div>
      <div style="padding:1.25rem 1.75rem;background:#111a0b;border-left:1px solid rgba(137,243,55,0.08);">
        <div style="font-family:'Courier New',monospace;font-size:9px;color:#6a8a5a;letter-spacing:0.12em;margin-bottom:6px;">CLICK_THROUGH_RATE</div>
        <div style="font-family:'Sora',sans-serif;font-size:1.4rem;font-weight:800;color:#89F337;">3.82% <span style="font-size:12px;color:#82976E;font-weight:400;">vs 0.9% industry</span></div>
      </div>
      <div style="padding:1.25rem 1.75rem;background:#111a0b;border-left:1px solid rgba(137,243,55,0.08);">
        <div style="font-family:'Courier New',monospace;font-size:9px;color:#6a8a5a;letter-spacing:0.12em;margin-bottom:6px;">FOLLOWER_GROWTH</div>
        <div style="font-family:'Sora',sans-serif;font-size:1.4rem;font-weight:800;color:#89F337;">+400 <span style="font-size:12px;color:#82976E;font-weight:400;">in 18 hours</span></div>
      </div>
    </div>
  </div>
</section>

<!-- PLATFORMS -->
<section style="background:#F6FBF0;padding:5rem 0;border-bottom:1px solid rgba(38,53,25,0.07);">
  <div style="max-width:1200px;margin:0 auto;padding:0 48px;box-sizing:border-box;">
    <div class="fade-up" style="margin-bottom:2.5rem;">
      <span style="font-family:'Sora',sans-serif;font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:0.5rem;">Where We Run</span>
      <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3vw,2.5rem);font-weight:800;color:#263519;letter-spacing:-0.02em;margin:0;">Every platform your customers are on.</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:rgba(38,53,25,0.08);border:1px solid rgba(38,53,25,0.08);" class="platforms-grid">
      <div class="fade-up platform-card" style="background:#fff;padding:2rem 1.5rem;"><div style="width:40px;height:40px;background:#263519;border-radius:6px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;"><svg width="20" height="20" viewBox="0 0 24 24" fill="#89F337"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></div><h3 style="font-family:'Sora',sans-serif;font-size:15px;font-weight:700;color:#263519;margin:0 0 8px;">Meta</h3><p style="font-family:'Sora',sans-serif;font-size:13px;color:#82976E;line-height:1.65;margin:0;">Facebook & Instagram ads. Reach, retarget, and convert your ideal dining customer.</p></div>
      <div class="fade-up platform-card" style="background:#fff;padding:2rem 1.5rem;"><div style="width:40px;height:40px;background:#263519;border-radius:6px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;"><svg width="20" height="20" viewBox="0 0 24 24" fill="#89F337"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/></svg></div><h3 style="font-family:'Sora',sans-serif;font-size:15px;font-weight:700;color:#263519;margin:0 0 8px;">TikTok</h3><p style="font-family:'Sora',sans-serif;font-size:13px;color:#82976E;line-height:1.65;margin:0;">Discovery-first video ads. Content that earns attention before spending budget.</p></div>
      <div class="fade-up platform-card" style="background:#fff;padding:2rem 1.5rem;"><div style="width:40px;height:40px;background:#263519;border-radius:6px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;"><svg width="20" height="20" viewBox="0 0 24 24" fill="#89F337"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg></div><h3 style="font-family:'Sora',sans-serif;font-size:15px;font-weight:700;color:#263519;margin:0 0 8px;">Google</h3><p style="font-family:'Sora',sans-serif;font-size:13px;color:#82976E;line-height:1.65;margin:0;">Search & display capturing high-intent buyers actively looking for a place to eat.</p></div>
      <div class="fade-up platform-card" style="background:#fff;padding:2rem 1.5rem;"><div style="width:40px;height:40px;background:#263519;border-radius:6px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;"><svg width="20" height="20" viewBox="0 0 24 24" fill="#89F337"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.248l-1.97 9.289c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.48 13.802l-2.95-.924c-.64-.203-.654-.64.136-.953l11.57-4.461c.537-.194 1.006.131.326.784z"/></svg></div><h3 style="font-family:'Sora',sans-serif;font-size:15px;font-weight:700;color:#263519;margin:0 0 8px;">Grab</h3><p style="font-family:'Sora',sans-serif;font-size:13px;color:#82976E;line-height:1.65;margin:0;">Delivery platform ads reaching hungry customers at the exact moment of decision.</p></div>
      <div class="fade-up platform-card" style="background:#fff;padding:2rem 1.5rem;"><div style="width:40px;height:40px;background:#263519;border-radius:6px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;"><svg width="20" height="20" viewBox="0 0 24 24" fill="#89F337"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.630 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.07 9.436-6.977C23.176 14.393 24 12.458 24 10.314"/></svg></div><h3 style="font-family:'Sora',sans-serif;font-size:15px;font-weight:700;color:#263519;margin:0 0 8px;">LINE MAN</h3><p style="font-family:'Sora',sans-serif;font-size:13px;color:#82976E;line-height:1.65;margin:0;">Thailand's #1 delivery app. Campaigns built for the platform Bangkok actually uses.</p></div>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section style="background:#263519;padding:5rem 0;">
  <div style="max-width:1200px;margin:0 auto;padding:0 48px;box-sizing:border-box;">
    <div class="fade-up" style="margin-bottom:2.5rem;">
      <span style="font-family:'Courier New',monospace;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:#6a8a5a;display:block;margin-bottom:6px;">// process.sequence</span>
      <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3vw,2.5rem);font-weight:800;color:#F6FBF0;letter-spacing:-0.02em;margin:0;">How we run your ads.</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(137,243,55,0.08);" class="process-grid">
      <div class="fade-up" style="padding:2.5rem 2rem;"><div style="font-family:'Courier New',monospace;font-size:2rem;font-weight:700;color:#89F337;line-height:1;margin-bottom:1rem;text-shadow:0 0 20px rgba(137,243,55,0.4);">01_</div><h3 style="font-family:'Sora',sans-serif;font-size:15px;font-weight:700;color:#F6FBF0;margin:0 0 10px;">Audit</h3><p style="font-family:'Sora',sans-serif;font-size:13px;color:#A8BFA0;line-height:1.7;margin:0;">We review your current ads, audiences, and spend. Find what's wasting money and what's worth scaling.</p></div>
      <div class="fade-up" style="padding:2.5rem 2rem;border-left:1px solid rgba(137,243,55,0.08);"><div style="font-family:'Courier New',monospace;font-size:2rem;font-weight:700;color:#89F337;line-height:1;margin-bottom:1rem;text-shadow:0 0 20px rgba(137,243,55,0.4);">02_</div><h3 style="font-family:'Sora',sans-serif;font-size:15px;font-weight:700;color:#F6FBF0;margin:0 0 10px;">Strategy</h3><p style="font-family:'Sora',sans-serif;font-size:13px;color:#A8BFA0;line-height:1.7;margin:0;">Platform selection, audience mapping, budget allocation. A plan built around your actual goals.</p></div>
      <div class="fade-up" style="padding:2.5rem 2rem;border-left:1px solid rgba(137,243,55,0.08);"><div style="font-family:'Courier New',monospace;font-size:2rem;font-weight:700;color:#89F337;line-height:1;margin-bottom:1rem;text-shadow:0 0 20px rgba(137,243,55,0.4);">03_</div><h3 style="font-family:'Sora',sans-serif;font-size:15px;font-weight:700;color:#F6FBF0;margin:0 0 10px;">Launch</h3><p style="font-family:'Sora',sans-serif;font-size:13px;color:#A8BFA0;line-height:1.7;margin:0;">We build the creative, set the audiences, and go live. You focus on running your restaurant.</p></div>
      <div class="fade-up" style="padding:2.5rem 2rem;border-left:1px solid rgba(137,243,55,0.08);"><div style="font-family:'Courier New',monospace;font-size:2rem;font-weight:700;color:#89F337;line-height:1;margin-bottom:1rem;text-shadow:0 0 20px rgba(137,243,55,0.4);">04_</div><h3 style="font-family:'Sora',sans-serif;font-size:15px;font-weight:700;color:#F6FBF0;margin:0 0 10px;">Scale</h3><p style="font-family:'Sora',sans-serif;font-size:13px;color:#A8BFA0;line-height:1.7;margin:0;">Weekly optimisation. Cut what underperforms, double what works. Steady, predictable growth.</p></div>
    </div>
  </div>
</section>

<!-- RESULTS -->
<section style="background:#F6FBF0;padding:5rem 0;border-bottom:1px solid rgba(38,53,25,0.07);">
  <div style="max-width:1200px;margin:0 auto;padding:0 48px;box-sizing:border-box;">
    <div class="fade-up" style="margin-bottom:2.5rem;">
      <span style="font-family:'Sora',sans-serif;font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:0.5rem;">Proof</span>
      <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3vw,2.5rem);font-weight:800;color:#263519;letter-spacing:-0.02em;margin:0;">Real numbers from real campaigns.</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(38,53,25,0.08);border:1px solid rgba(38,53,25,0.08);" class="results-grid">
