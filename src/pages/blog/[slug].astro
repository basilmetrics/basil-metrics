---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [
    {
      params: { slug: 'delivery-brand-tiktok-scale' },
      props: {
        title: 'How a Delivery-First F&B Brand Scaled to 1M TikTok Views in 45 Days',
        date: '2025-03-15', category: 'Ads', mins: 6,
        img: 'https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1200&q=80',
        body: '<p>This is a placeholder post. Add your content via the CMS at <code>/admin</code>.</p>',
      },
    },
    {
      params: { slug: 'roas-formula-fb-brands' },
      props: {
        title: 'The ROAS Formula: Why Most Bangkok F&B Brands Waste Their Ad Budget',
        date: '2025-02-22', category: 'Marketing', mins: 5,
        img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1200&q=80',
        body: '<p>Placeholder post — add content via /admin CMS.</p>',
      },
    },
    {
      params: { slug: 'food-brand-identity-framework' },
      props: {
        title: 'Building a Food Brand Identity That Scales: A Bangkok Framework',
        date: '2025-01-10', category: 'Branding', mins: 7,
        img: 'https://images.unsplash.com/photo-1493770348161-369560ae357d?w=1200&q=80',
        body: '<p>Placeholder post — add content via /admin CMS.</p>',
      },
    },
  ];
}

const { title, date, category, mins, img, body } = Astro.props;
const d = new Date(date).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });
---

<BaseLayout {title} description={title} ogImage={img} readingProgress={true}>
<div style="background:#F6FBF0;min-height:100vh;">
  <div style="max-width:760px;margin:0 auto;padding:4rem 2rem 7rem;">

    <a href="/blog" style="font-family:'Sora',sans-serif;font-size:0.8rem;color:#82976E;text-decoration:none;display:inline-block;margin-bottom:2.5rem;">← All Posts</a>

    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;flex-wrap:wrap;">
      <span style="font-family:'Sora',sans-serif;font-size:0.6rem;background:rgba(130,151,110,0.12);color:#82976E;border-radius:99px;padding:0.18rem 0.65rem;">{category}</span>
      <span style="font-family:'Sora',sans-serif;font-size:0.78rem;color:#82976E;">{d} · {mins} min read</span>
    </div>

    <h1 style="font-size:clamp(1.75rem,3.5vw,2.75rem);color:#263519;line-height:1.12;margin-bottom:2.5rem;">{title}</h1>

    {img && (
      <div style="margin-bottom:3rem;overflow:hidden;border:1px solid rgba(38,53,25,0.08);">
        <img src={img} alt={title} style="width:100%;object-fit:cover;display:block;" loading="eager" />
      </div>
    )}

    <div class="prose" set:html={body} />

    <div style="margin-top:3.5rem;padding-top:2rem;border-top:1px solid rgba(38,53,25,0.08);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;">
      <a href="/blog" style="font-family:'Sora',sans-serif;font-size:0.8rem;color:#82976E;text-decoration:none;">← All Posts</a>
      <a href="/contact" class="btn-lime" style="font-size:0.82rem;padding:0.7rem 1.5rem;">Work With Us</a>
    </div>

  </div>
</div>
</BaseLayout>
