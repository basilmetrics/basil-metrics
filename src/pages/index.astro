<script>
  const targets = [
    { el: document.getElementById('s-cpc'),    to:0.62, prefix:'฿', suffix:'',  decimals:2 },
    { el: document.getElementById('s-follow'), to:400,  prefix:'+', suffix:'',  decimals:0 },
    { el: document.getElementById('s-ctr'),    to:3.82, prefix:'',  suffix:'%', decimals:2 },
  ];
  function easeOut(t){ return 1-Math.pow(1-t,3); }
  function runCount(){
    const dur=2200, start=performance.now();
    function tick(now){
      const ease=easeOut(Math.min((now-start)/dur,1));
      targets.forEach(({el,to,prefix,suffix,decimals})=>{ if(el) el.textContent=prefix+(ease*to).toFixed(decimals)+suffix; });
      if((now-start)<dur) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  const heroEl=document.getElementById('hero');
  if(heroEl) new IntersectionObserver((e,o)=>{ if(e[0].isIntersecting){runCount();o.disconnect();} },{threshold:0.3}).observe(heroEl);
  document.addEventListener('astro:page-load',()=>{
    const h=document.getElementById('hero');
    if(h) new IntersectionObserver((e,o)=>{ if(e[0].isIntersecting){runCount();o.disconnect();} },{threshold:0.3}).observe(h);
  });
  const line=document.getElementById('how-line');
  if(line) new IntersectionObserver((e,o)=>{ if(e[0].isIntersecting){line.classList.add('line-in');o.disconnect();} },{threshold:0.2}).observe(line);
</script>

