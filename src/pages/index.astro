---
import { getEntry } from "astro:content";
import BaseLayout from '../layouts/BaseLayout.astro';

const hp = await getEntry("homepage", "settings");
const { hero_line1, hero_line2, hero_subtext, stat1_label, stat1_value, stat2_label, stat2_value, stat3_label, stat3_value } = hp.data;

const services = [
  { n: '01', name: 'Brand Architecture', desc: 'Visual identity systems designed to scale — from single outlet to multi-location franchise.' },
  { n: '02', name: 'Performance Ads', desc: 'Meta, Google, and TikTok campaigns structured for measurable, attributable return.' },
  { n: '03', name: 'Creative Direction', desc: 'Photography, video, and copy that earns attention before spending a single baht of budget.' },
  { n: '04', name: 'Growth Analytics', desc: 'Clear reporting on ROAS, CPA, and LTV. Real numbers, acted on fast.' },
];

const results = [
  { category: 'Dessert & F&B Brand', platform: 'Meta', metric: '0.62 ฿ per click', detail: '14,399 profile & LINE visits · 3.82% CTR · ฿8,935 total spend', benchmark: 'Industry avg: ~฿110 cost per lead (WordStream)', label: 'Beating the Feed' },
  { category: 'Dessert & F&B Brand', platform: 'TikTok', metric: '+400 followers in 18 hrs', detail: '547 new followers/day · account reached 94.6K · on track for 100K', benchmark: 'Industry avg: 2–3% monthly growth (Rival IQ)', label: 'The Viral Sprint' },
  { category: 'Premium Retail Brand', platform: 'Google', metric: '4.75 ฿ per click', detail: '~1,000 high-intent clicks · 4.30% CTR · bottom-of-funnel traffic', benchmark: 'Industry avg: ~฿118 CPC for retail (WordStream)', label: 'Capturing the Buyer' },
];

const tickerItems = [
  'Performance Ads', 'Brand Strategy', 'Meta Campaigns', 'TikTok Creative',
  'Google Ads', 'ROAS Optimisation', 'Creative Direction', 'F&B Marketing',
  'Conversion Tracking', 'Delivery Brands', 'Dine-In Strategy', 'Campaign Analytics',
];
---

<BaseLayout
  schema={{"@context":"https://schema.org","@graph":[{"@type":["MarketingAgency","LocalBusiness"],"@id":"https://basilmetrics.com/#organization","name":"Basil Metrics","url":"https://basilmetrics.com","logo":"https://basilmetrics.com/logo.svg","description":"Performance marketing agency specializing in Meta, TikTok and Google ads for F&B and retail brands in Bangkok, Thailand.","areaServed":{"@type":"City","name":"Bangkok"},"address":{"@type":"PostalAddress","addressLocality":"Bangkok","addressCountry":"TH"},"priceRange":"฿฿","knowsAbout":["Meta Ads","TikTok Marketing","Google Ads","F&B Marketing","ROAS Optimization","Brand Strategy","Performance Marketing","Content Creation"]},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How much do Meta ads cost for Bangkok restaurants?","acceptedAnswer":{"@type":"Answer","text":"The industry average is ฿110 per lead. Basil Metrics campaigns average ฿0.62 per click."}},{"@type":"Question","name":"Which platforms work best for F&B marketing in Bangkok?","acceptedAnswer":{"@type":"Answer","text":"Meta drives direct traffic. TikTok drives discovery. Google captures high-intent buyers. Basil Metrics runs all three."}},{"@type":"Question","name":"What is ROAS and why does it matter for Bangkok restaurants?","acceptedAnswer":{"@type":"Answer","text":"ROAS measures revenue generated per baht spent on advertising. Tracking it across Meta, TikTok and Google is essential to scaling profitably."}}]},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://basilmetrics.com"}]}]}}
  title="Bangkok F&B Performance Marketing Agency | Basil Metrics"
  description="Meta, TikTok & Google ads for Bangkok restaurants & F&B brands. ฿0.62 cost per click. Real ROAS. Book a free strategy call today."
>

<section id="hero" transition:name="hero-section" style="background:#263519;min-height:100vh;display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden;">
  <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;z-index:0;background-image:url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E\");background-repeat:repeat;background-size:200px 200px;opacity:0.35;"></div>
  <div style="max-width:1200px;margin:0 auto;padding:140px 2rem 80px;width:100%;position:relative;z-index:1;">
    <p class="fade-up" style="color:#89F337;font-family:'Sora',sans-serif;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;margin:0 0 28px;">Bangkok, Thailand — F&amp;B Performance Marketing</p>
    <h1 class="fade-up" style="color:#F6FBF0;font-family:'Sora',sans-serif;font-size:clamp(2.4rem,5.5vw,4.4rem);font-weight:800;line-height:1.08;letter-spacing:-0.025em;max-width:860px;margin:0 0 28px;">
      Bangkok's F&amp;B Brands Don't Need More Ads.<br/>
      <span style="color:#89F337;">They Need Better Ones.</span>
    </h1>
    <p class="fade-up" style="color:#82976E;font-family:'Sora',sans-serif;font-size:clamp(1rem,1.8vw,1.15rem);font-weight:400;line-height:1.7;max-width:540px;margin:0 0 56px;">{hero_subtext}</p>
    <div class="fade-up v4-stats" style="display:flex;gap:0;margin-bottom:52px;border:1px solid rgba(246,251,240,0.1);max-width:600px;">
      <div style="flex:1;padding:20px 24px;border-right:1px solid rgba(246,251,240,0.1);">
        <div id="s-cpc" style="color:#89F337;font-family:'Sora',sans-serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:800;line-height:1;margin-bottom:6px;">฿0.00</div>
        <div style="color:#82976E;font-family:'Sora',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;">{stat1_label}</div>
      </div>
      <div style="flex:1;padding:20px 24px;border-right:1px solid rgba(246,251,240,0.1);">
        <div id="s-follow" style="color:#89F337;font-family:'Sora',sans-serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:800;line-height:1;margin-bottom:6px;">+0</div>
        <div style="color:#82976E;font-family:'Sora',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;">{stat2_label}</div>
      </div>
      <div style="flex:1;padding:20px 24px;">
        <div id="s-ctr" style="color:#89F337;font-family:'Sora',sans-serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:800;line-height:1;margin-bottom:6px;">0.00%</div>
        <div style="color:#82976E;font-family:'Sora',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;">{stat3_label}</div>
      </div>
    </div>
    <div class="fade-up" style="display:flex;gap:16px;flex-wrap:wrap;align-items:center;">
      <a href="/contact" style="display:inline-flex;align-items:center;gap:8px;background:#89F337;color:#263519;font-family:'Sora',sans-serif;font-size:14px;font-weight:700;padding:15px 32px;border-radius:3px;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='.88'" onmouseout="this.style.opacity='1'">Get a free audit <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="#263519" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      <a href="/portfolio" style="display:inline-flex;align-items:center;gap:8px;color:#F6FBF0;font-family:'Sora',sans-serif;font-size:14px;font-weight:500;padding:15px 24px;text-decoration:none;border:1px solid rgba(130,151,110,0.35);border-radius:3px;transition:border-color 0.2s;" onmouseover="this.style.borderColor='#82976E'" onmouseout="this.style.borderColor='rgba(130,151,110,0.35)'">See our work</a>
    </div>
  </div>
  <div aria-hidden="true" style="border-top:1px solid rgba(130,151,110,0.2);padding:16px 0;overflow:hidden;position:relative;z-index:1;">
    <div class="v4-ticker" style="display:flex;width:max-content;">
      {[...tickerItems,...tickerItems].map(item => (
        <span style="color:#82976E;font-family:'Sora',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;white-space:nowrap;padding:0 28px;">{item}<span style="color:#89F337;margin-left:28px;">✦</span></span>
      ))}
    </div>
  </div>
</section>

<section style="background:#F6FBF0;padding:6rem 2rem;border-bottom:1px solid rgba(38,53,25,0.07);">
  <div style="max-width:1200px;margin:0 auto;">
    <div class="fade-up" style="margin-bottom:3rem;">
      <span style="font-family:'Sora',sans-serif;font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:0.5rem;">What We Do</span>
      <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3vw,2.5rem);font-weight:800;color:#263519;letter-spacing:-0.02em;margin:0;">Two things we do exceptionally well.</h2>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;" class="pillars-grid">
      <a href="/ads-work" transition:name="pillar-ads" style="display:block;background:#263519;padding:3rem;text-decoration:none;border-radius:4px;position:relative;overflow:hidden;transition:transform 0.25s,box-shadow 0.25s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 20px 48px rgba(38,53,25,0.25)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
        <span style="font-family:'Sora',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#89F337;display:block;margin-bottom:1.5rem;">Ads Work</span>
        <h3 style="font-family:'Sora',sans-serif;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:800;color:#F6FBF0;line-height:1.15;letter-spacing:-0.02em;margin:0 0 1.25rem;">Performance<br/>advertising that<br/>actually converts.</h3>
        <p style="font-family:'Sora',sans-serif;font-size:13px;color:#82976E;line-height:1.7;margin:0 0 2rem;">Meta · TikTok · Google · Grab · LINE MAN</p>
        <span style="display:inline-flex;align-items:center;gap:8px;color:#89F337;font-family:'Sora',sans-serif;font-size:13px;font-weight:600;">See results <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="#89F337" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a href="/brand-work" transition:name="pillar-brand" style="display:block;background:#263519;padding:3rem;text-decoration:none;border-radius:4px;position:relative;overflow:hidden;transition:transform 0.25s,box-shadow 0.25s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 20px 48px rgba(38,53,25,0.25)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
        <span style="font-family:'Sora',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#89F337;display:block;margin-bottom:1.5rem;">Brand Work</span>
        <h3 style="font-family:'Sora',sans-serif;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:800;color:#F6FBF0;line-height:1.15;letter-spacing:-0.02em;margin:0 0 1.25rem;">Brands built to<br/>be remembered<br/>and recognised.</h3>
        <p style="font-family:'Sora',sans-serif;font-size:13px;color:#82976E;line-height:1.7;margin:0 0 2rem;">Identity · Photography · Creative Direction</p>
        <span style="display:inline-flex;align-items:center;gap:8px;color:#89F337;font-family:'Sora',sans-serif;font-size:13px;font-weight:600;">View work <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="#89F337" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
    </div>
  </div>
</section>

<div style="background:#F6FBF0;">
  <section style="background:#F6FBF0;max-width:100%;padding:5.5rem 2rem;border-bottom:1px solid rgba(38,53,25,0.07);">
    <div style="max-width:1200px;margin:0 auto;">
      <div class="fade-up" style="margin-bottom:2.5rem;"><span style="font-family:'Sora',sans-serif;font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:0.6rem;">What We Do</span><h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3vw,2.5rem);font-weight:800;color:#263519;letter-spacing:-0.02em;">Services</h2></div>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:rgba(38,53,25,0.08);border:1px solid rgba(38,53,25,0.08);" class="services-grid">
        {services.map(s => (
          <div class="fade-up card-lift" style="background:#FFFFFF;padding:2.5rem;" onmouseover="this.style.background='#F6FBF0'" onmouseout="this.style.background='#FFFFFF'">
            <p style="font-family:'Sora',sans-serif;font-size:0.58rem;color:#82976E;font-weight:600;letter-spacing:0.1em;margin-bottom:1.1rem;">{s.n}</p>
            <h3 style="font-family:'Sora',sans-serif;font-size:1.05rem;font-weight:700;color:#263519;margin-bottom:0.65rem;">{s.name}</h3>
            <p style="font-family:'Sora',sans-serif;font-size:0.875rem;color:#82976E;line-height:1.68;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="max-width:1200px;margin:0 auto;padding:5.5rem 2rem;border-bottom:1px solid rgba(38,53,25,0.07);">
    <div class="fade-up" style="margin-bottom:2.5rem;"><span style="font-family:'Sora',sans-serif;font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:0.6rem;">Proof of Work</span><h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3vw,2.5rem);font-weight:800;color:#263519;letter-spacing:-0.02em;">Results</h2></div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:rgba(38,53,25,0.08);border:1px solid rgba(38,53,25,0.08);" class="results-grid">
      {results.map(r => (
        <div class="fade-up card-lift" style="background:#FFFFFF;padding:2.25rem;display:flex;flex-direction:column;justify-content:space-between;">
          <div>
            <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:1.25rem;flex-wrap:wrap;"><span style="font-family:'Sora',sans-serif;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:#82976E;font-weight:600;">{r.category}</span><span style="font-family:'Sora',sans-serif;font-size:0.6rem;background:rgba(137,243,54,0.15);color:#263519;border-radius:99px;padding:0.18rem 0.65rem;font-weight:600;">{r.platform}</span></div>
            <p style="font-family:'Sora',sans-serif;font-size:0.7rem;color:#82976E;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;margin-bottom:0.5rem;">{r.label}</p>
            <p style="font-family:'Sora',sans-serif;font-size:1.75rem;font-weight:800;color:#263519;line-height:1.1;margin-bottom:0.75rem;">{r.metric}</p>
            <p style="font-family:'Sora',sans-serif;font-size:0.8rem;color:#263519;line-height:1.6;margin-bottom:1rem;">{r.detail}</p>
          </div>
          <div style="border-top:1px solid rgba(38,53,25,0.07);padding-top:0.85rem;margin-top:0.5rem;"><p style="font-family:'Sora',sans-serif;font-size:0.72rem;color:#82976E;line-height:1.55;font-style:italic;">{r.benchmark}</p></div>
        </div>
      ))}
    </div>
  </section>

  <section style="max-width:1200px;margin:0 auto;padding:5.5rem 2rem;border-bottom:1px solid rgba(38,53,25,0.07);">
    <div class="fade-up" style="margin-bottom:2.5rem;"><span style="font-family:'Sora',sans-serif;font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:0.6rem;">Our Process</span><h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3vw,2.5rem);font-weight:800;color:#263519;letter-spacing:-0.02em;">How We Work</h2></div>
    <div style="border-top:1px solid rgba(38,53,25,0.08);" class="how-work-wrap"><div class="how-work-line" id="how-line"></div>
      <div class="fade-up how-step"><div style="font-family:'Sora',sans-serif;font-size:2.75rem;font-weight:800;color:#89F337;line-height:1;margin-bottom:0.75rem;">01</div><div><h3 style="font-family:'Sora',sans-serif;font-size:1rem;font-weight:700;color:#263519;margin-bottom:0.5rem;">We look at what's really going on.</h3><p style="font-family:'Sora',sans-serif;font-size:0.875rem;color:#82976E;line-height:1.7;">Before we spend a single baht of your money, we look at your current setup. We check your social feeds, your past ads, and how customers actually book a table to see what's working and what needs fixing.</p></div></div>
      <div class="fade-up how-step"><div style="font-family:'Sora',sans-serif;font-size:2.75rem;font-weight:800;color:#89F337;line-height:1;margin-bottom:0.75rem;">02</div><div><h3 style="font-family:'Sora',sans-serif;font-size:1rem;font-weight:700;color:#263519;margin-bottom:0.5rem;">You pick exactly what you need.</h3><p style="font-family:'Sora',sans-serif;font-size:0.875rem;color:#82976E;line-height:1.7;">No bloated agency retainers. We give you a clear menu of what we can do. If you just need us to run your ads, great. If you need us to shoot photos, make Reels, and handle the ads, we can do that too. You only pay for what actually helps you grow.</p></div></div>
      <div class="fade-up how-step"><div style="font-family:'Sora',sans-serif;font-size:2.75rem;font-weight:800;color:#89F337;line-height:1;margin-bottom:0.75rem;">03</div><div><h3 style="font-family:'Sora',sans-serif;font-size:1rem;font-weight:700;color:#263519;margin-bottom:0.5rem;">We build and launch.</h3><p style="font-family:'Sora',sans-serif;font-size:0.875rem;color:#82976E;line-height:1.7;">Our team of five takes over the heavy lifting. We create the content, set up your audiences, fix your LINE OA, and get your campaigns running so you can focus on running your restaurant.</p></div></div>
      <div class="fade-up how-step" style="border-bottom:none;"><div style="font-family:'Sora',sans-serif;font-size:2.75rem;font-weight:800;color:#89F337;line-height:1;margin-bottom:0.75rem;">04</div><div><h3 style="font-family:'Sora',sans-serif;font-size:1rem;font-weight:700;color:#263519;margin-bottom:0.5rem;">We keep the tables full.</h3><p style="font-family:'Sora',sans-serif;font-size:0.875rem;color:#82976E;line-height:1.7;">A one-off viral video is fun, but it doesn't pay the rent. We watch your ad spend closely every week, making adjustments to ensure you are getting steady, predictable foot traffic month after month.</p></div></div>
    </div>
  </section>

  <section style="max-width:1200px;margin:0 auto;padding:5.5rem 2rem;border-bottom:1px solid rgba(38,53,25,0.07);">
    <div class="fade-up" style="margin-bottom:2.5rem;"><span style="font-family:'Sora',sans-serif;font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:0.6rem;">Got Questions</span><h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3vw,2.5rem);font-weight:800;color:#263519;letter-spacing:-0.02em;">Frequently Asked Questions</h2></div>
    <div style="border-top:1px solid rgba(38,53,25,0.08);">
      <details class="faq-item fade-up"><summary style="font-family:'Sora',sans-serif;font-size:0.92rem;font-weight:600;color:#263519;padding:1.25rem 0;display:flex;justify-content:space-between;align-items:center;cursor:pointer;list-style:none;">Do you only work with big restaurant chains?<span class="faq-plus" style="font-size:1.4rem;color:#89F337;font-weight:300;transition:transform 0.2s;min-width:20px;text-align:center;">+</span></summary><div style="font-family:'Sora',sans-serif;font-size:0.875rem;color:#82976E;line-height:1.7;padding-bottom:1.25rem;">Not at all. While we do work with established hospitality groups, we really love partnering with independent founders — whether you're opening a specialty coffee shop, a neighborhood bakery, or a new tapas bar.</div></details>
      <details class="faq-item fade-up"><summary style="font-family:'Sora',sans-serif;font-size:0.92rem;font-weight:600;color:#263519;padding:1.25rem 0;display:flex;justify-content:space-between;align-items:center;cursor:pointer;list-style:none;">How much does it cost to work with you?<span class="faq-plus" style="font-size:1.4rem;color:#89F337;font-weight:300;transition:transform 0.2s;min-width:20px;text-align:center;">+</span></summary><div style="font-family:'Sora',sans-serif;font-size:0.875rem;color:#82976E;line-height:1.7;padding-bottom:1.25rem;">It depends entirely on what you need. Our projects start at 5,000 THB, and we build a custom price based strictly on the exact services you choose.</div></details>
      <details class="faq-item fade-up"><summary style="font-family:'Sora',sans-serif;font-size:0.92rem;font-weight:600;color:#263519;padding:1.25rem 0;display:flex;justify-content:space-between;align-items:center;cursor:pointer;list-style:none;">Do you shoot photos and videos, or just run ads?<span class="faq-plus" style="font-size:1.4rem;color:#89F337;font-weight:300;transition:transform 0.2s;min-width:20px;text-align:center;">+</span></summary><div style="font-family:'Sora',sans-serif;font-size:0.875rem;color:#82976E;line-height:1.7;padding-bottom:1.25rem;">We do both. We're a dedicated team of five — we shoot the photos and videos that capture the actual vibe of your venue, then run the ads to make sure people see them.</div></details>
      <details class="faq-item fade-up"><summary style="font-family:'Sora',sans-serif;font-size:0.92rem;font-weight:600;color:#263519;padding:1.25rem 0;display:flex;justify-content:space-between;align-items:center;cursor:pointer;list-style:none;">Where do you run the ads?<span class="faq-plus" style="font-size:1.4rem;color:#89F337;font-weight:300;transition:transform 0.2s;min-width:20px;text-align:center;">+</span></summary><div style="font-family:'Sora',sans-serif;font-size:0.875rem;color:#82976E;line-height:1.7;padding-bottom:1.25rem;">Wherever your customers are — Instagram, Facebook, TikTok, Google Search, and delivery campaigns inside Grab and LINE MAN.</div></details>
