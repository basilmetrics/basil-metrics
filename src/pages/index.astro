---
import { getEntry } from "astro:content";
import BaseLayout from '../layouts/BaseLayout.astro';

const hp = await getEntry("homepage", "settings");
const { hero_line1, hero_line2, hero_subtext, stat1_label, stat1_value, stat2_label, stat2_value, stat3_label, stat3_value } = hp.data;
const services = [
  { n: '01', name: 'Brand Architecture', desc: 'Visual identity systems designed to scale — from single outlet to multi-location franchise.' },
  { n: '02', name: 'Performance Ads', desc: 'Meta, Google, and TikTok campaigns structured for measurable, attributable return.' },
  { n: '03', name: 'Creative Direction', desc: 'Photography, video, and copy that earns attention before spending a single baht of budget.' },
  { n: '04', name: 'Growth Analytics', desc: 'Clear reporting on ROAS, CPA, and LTV. Real numbers, acted on fast.' },
];

const results = [
  {
    category: 'Dessert & F&B Brand',
    platform: 'Meta',
    metric: '0.62 ฿ per click',
    detail: '14,399 profile & LINE visits · 3.82% CTR · ฿8,935 total spend',
    benchmark: 'Industry avg: ~฿110 cost per lead (WordStream)',
    label: 'Beating the Feed',
  },
  {
    category: 'Dessert & F&B Brand',
    platform: 'TikTok',
    metric: '+400 followers in 18 hrs',
    detail: '547 new followers/day · account reached 94.6K · on track for 100K',
    benchmark: 'Industry avg: 2–3% monthly growth (Rival IQ)',
    label: 'The Viral Sprint',
  },
  {
    category: 'Premium Retail Brand',
    platform: 'Google',
    metric: '4.75 ฿ per click',
    detail: '~1,000 high-intent clicks · 4.30% CTR · bottom-of-funnel traffic',
    benchmark: 'Industry avg: ~฿118 CPC for retail (WordStream)',
    label: 'Capturing the Buyer',
  },
];

const tickerItems = [
  'Performance Ads', 'Brand Strategy', 'Meta Campaigns', 'TikTok Creative',
  'Google Ads', 'ROAS Optimisation', 'Creative Direction', 'F&B Marketing',
  'Conversion Tracking', 'Delivery Brands', 'Dine-In Strategy', 'Campaign Analytics',
];
---

<BaseLayout
  title="Basil Metrics — Performance Marketing for Bangkok F&B Brands"
  description="Strategy, creative, and paid media for Bangkok's most ambitious food and F&B brands. Campaigns built to convert."
>

<div style="background:#F6FBF0;">

  <!-- HERO -->
  <section style="background:#F6FBF0;min-height:90vh;display:flex;flex-direction:column;justify-content:center;padding:6rem 2rem 4rem;border-bottom:1px solid rgba(38,53,25,0.08);">
    <div style="max-width:1200px;margin:0 auto;width:100%;">
      <span style="font-family:'Sora',sans-serif;font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:1.5rem;">Bangkok, Thailand — F&B Performance Marketing</span>
      <h1 style="font-family:'Sora',sans-serif;font-size:clamp(2.8rem,6.5vw,6rem);font-weight:800;line-height:1.0;letter-spacing:-0.03em;color:#263519;margin-bottom:1.5rem;max-width:900px;">
        {hero_line1}<br />
        <em style="font-style:normal;color:#89F337;">Convert.</em><br />
        {hero_line2}
      </h1>
      <p style="font-family:'Sora',sans-serif;font-size:1.05rem;color:#82976E;max-width:480px;line-height:1.72;margin-bottom:3rem;font-weight:400;">
        We combine brand strategy, creative production, and paid media into campaigns that move real numbers for Bangkok's food and F&B brands.
      </p>

      <!-- Stats -->
      <div class="hero-stats" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(38,53,25,0.08);border:1px solid rgba(38,53,25,0.08);margin-bottom:2.75rem;">
        <div style="background:#F6FBF0;padding:1.25rem 1.5rem;">
          <p style="font-family:'Sora',sans-serif;font-size:0.58rem;letter-spacing:0.1em;text-transform:uppercase;color:#82976E;margin-bottom:0.35rem;">Cost Per Click</p>
          <p style="font-family:'Sora',sans-serif;font-size:2rem;font-weight:800;color:#263519;line-height:1;" id="s-cpc">{stat1_value}</p>
        </div>
        <div style="background:#F6FBF0;padding:1.25rem 1.5rem;">
          <p style="font-family:'Sora',sans-serif;font-size:0.58rem;letter-spacing:0.1em;text-transform:uppercase;color:#82976E;margin-bottom:0.35rem;">Follower Growth</p>
          <p style="font-family:'Sora',sans-serif;font-size:2rem;font-weight:800;color:#263519;line-height:1;" id="s-follow">{stat2_value}</p>
        </div>
        <div style="background:#F6FBF0;padding:1.25rem 1.5rem;">
          <p style="font-family:'Sora',sans-serif;font-size:0.58rem;letter-spacing:0.1em;text-transform:uppercase;color:#82976E;margin-bottom:0.35rem;">Avg CTR</p>
          <p style="font-family:'Sora',sans-serif;font-size:2rem;font-weight:800;color:#263519;line-height:1;" id="s-ctr">{stat3_value}</p>
        </div>
      </div>

      <div style="display:flex;gap:0.75rem;flex-direction:column;max-width:320px;">
        <a href="/contact" class="btn-lime">Start a Campaign</a>
        <a href="/portfolio" class="btn-ghost">View Case Studies</a>
      </div>
    </div>
  </section>

  <!-- TICKER -->
  <div class="ticker-outer" aria-hidden="true">
    <div class="ticker-inner">
      {[...tickerItems, ...tickerItems].map(item => (
        <span class="ticker-item"><span class="ticker-dot">◆</span>{item}</span>
      ))}
    </div>
  </div>

  <!-- SERVICES -->
  <section style="max-width:1200px;margin:0 auto;padding:5.5rem 2rem;border-bottom:1px solid rgba(38,53,25,0.07);">
    <div class="fade-up" style="margin-bottom:2.5rem;">
      <span style="font-family:'Sora',sans-serif;font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:0.6rem;">What We Do</span>
      <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3vw,2.5rem);font-weight:800;color:#263519;letter-spacing:-0.02em;">Services</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:rgba(38,53,25,0.08);border:1px solid rgba(38,53,25,0.08);" class="services-grid">
      {services.map(s => (
        <div class="fade-up" style="background:#FFFFFF;padding:2.5rem;transition:background 0.18s;" onmouseover="this.style.background='#F6FBF0'" onmouseout="this.style.background='#FFFFFF'">
          <p style="font-family:'Sora',sans-serif;font-size:0.58rem;color:#82976E;font-weight:600;letter-spacing:0.1em;margin-bottom:1.1rem;">{s.n}</p>
          <h3 style="font-family:'Sora',sans-serif;font-size:1.05rem;font-weight:700;color:#263519;margin-bottom:0.65rem;">{s.name}</h3>
          <p style="font-family:'Sora',sans-serif;font-size:0.875rem;color:#82976E;line-height:1.68;">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- RESULTS -->
  <section style="max-width:1200px;margin:0 auto;padding:5.5rem 2rem;border-bottom:1px solid rgba(38,53,25,0.07);">
    <div class="fade-up" style="margin-bottom:2.5rem;">
      <span style="font-family:'Sora',sans-serif;font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:0.6rem;">Proof of Work</span>
      <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.75rem,3vw,2.5rem);font-weight:800;color:#263519;letter-spacing:-0.02em;">Results</h2>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:rgba(38,53,25,0.08);border:1px solid rgba(38,53,25,0.08);" class="results-grid">
      {results.map(r => (
        <div class="fade-up" style="background:#FFFFFF;padding:2.25rem;display:flex;flex-direction:column;justify-content:space-between;">
          <div>
            <!-- Label + Platform -->
            <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:1.25rem;flex-wrap:wrap;">
              <span style="font-family:'Sora',sans-serif;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:#82976E;font-weight:600;">{r.category}</span>
              <span style="font-family:'Sora',sans-serif;font-size:0.6rem;background:rgba(137,243,54,0.15);color:#263519;border-radius:99px;padding:0.18rem 0.65rem;font-weight:600;">{r.platform}</span>
            </div>
            <!-- Campaign label -->
            <p style="font-family:'Sora',sans-serif;font-size:0.7rem;color:#82976E;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;margin-bottom:0.5rem;">{r.label}</p>
            <!-- Big metric -->
            <p style="font-family:'Sora',sans-serif;font-size:1.75rem;font-weight:800;color:#263519;line-height:1.1;margin-bottom:0.75rem;">{r.metric}</p>
            <!-- Detail -->
            <p style="font-family:'Sora',sans-serif;font-size:0.8rem;color:#263519;line-height:1.6;margin-bottom:1rem;">{r.detail}</p>
          </div>
          <!-- Benchmark -->
          <div style="border-top:1px solid rgba(38,53,25,0.07);padding-top:0.85rem;margin-top:0.5rem;">
            <p style="font-family:'Sora',sans-serif;font-size:0.72rem;color:#82976E;line-height:1.55;font-style:italic;">{r.benchmark}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section style="max-width:1200px;margin:0 auto;padding:5.5rem 2rem 7rem;">
    <div class="fade-up" style="background:#263519;padding:4rem 3.5rem;">
      <div style="display:grid;grid-template-columns:1fr auto;gap:3rem;align-items:center;" class="cta-inner">
        <div>
          <span style="font-family:'Sora',sans-serif;font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(130,151,110,0.6);font-weight:500;display:block;margin-bottom:0.75rem;">Ready to launch</span>
          <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.6rem,3vw,2.75rem);font-weight:800;color:#F6FBF0;margin-bottom:1rem;max-width:480px;line-height:1.1;letter-spacing:-0.02em;">
            Your Next Campaign Starts With One Conversation.
          </h2>
          <p style="font-family:'Sora',sans-serif;font-size:0.9rem;color:#82976E;line-height:1.7;max-width:420px;">
            Tell us your brand, your goals, your budget. We'll map out a campaign that actually converts.
          </p>
        </div>
        <div style="display:flex;flex-direction:column;gap:0.75rem;min-width:180px;">
          <a href="/contact" class="btn-lime" style="text-align:center;">Start a Campaign →</a>
          <a href="/portfolio" style="font-family:'Sora',sans-serif;font-size:0.78rem;color:#82976E;text-align:center;text-decoration:underline;text-underline-offset:3px;">View case studies</a>
        </div>
      </div>
    </div>
  </section>

</div>

<style>
  @media (max-width: 768px) {
    .hero-stats    { grid-template-columns: repeat(3,1fr) !important; }
    .hero-stats > div { padding: 0.75rem 0.4rem !important; }
    .hero-stats #s-cpc, .hero-stats #s-follow, .hero-stats #s-ctr { font-size: 1.1rem !important; }
    .services-grid { grid-template-columns: 1fr !important; }
    .results-grid  { grid-template-columns: 1fr !important; }
    .cta-inner     { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  const statsBox = document.querySelector('.hero-stats');
  if (!statsBox) throw new Error();

  const targets = [
    { el: document.getElementById('s-cpc'),    from: 0, to: 0.62, prefix: '฿', suffix: '',  decimals: 2 },
    { el: document.getElementById('s-follow'), from: 0, to: 400,  prefix: '+', suffix: '',  decimals: 0 },
    { el: document.getElementById('s-ctr'),    from: 0, to: 3.82, prefix: '',  suffix: '%', decimals: 2 },
  ];

  function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

  function runCount() {
    const duration = 800;
    const start = performance.now();
    function tick(now) {
      const t = Math.min((now - start) / duration, 1);
      const ease = easeOut(t);
      targets.forEach(({ el, from, to, prefix, suffix, decimals }) => {
        if (!el) return;
        const val = from + (to - from) * ease;
        el.textContent = prefix + val.toFixed(decimals) + suffix;
      });
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function resetCount() {
    targets.forEach(({ el, prefix, suffix, decimals }) => {
      if (!el) return;
      el.textContent = prefix + (0).toFixed(decimals) + suffix;
    });
  }

  new IntersectionObserver(([e]) => {
    if (e.isIntersecting) { runCount(); } else { resetCount(); }
  }, { threshold: 0.3 }).observe(statsBox);
</script>

</BaseLayout>

<style>
@media (max-width: 768px) {
  .hero-stats {
    display: flex !important;
    flex-direction: column !important;
    background: #FFFFFF !important;
    border: 1px solid rgba(38,53,25,0.08) !important;
    overflow: hidden !important;
  }
  .hero-stats > div {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 1rem 1.25rem !important;
    border-bottom: 1px solid rgba(38,53,25,0.08) !important;
    background: #FFFFFF !important;
    gap: 1rem !important;
  }
  .hero-stats > div:last-child {
    border-bottom: none !important;
  }
  .hero-stats > div > p:last-child {
    font-size: 1.75rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    order: -1 !important;
    min-width: 80px !important;
  }
  .hero-stats > div > p:first-child {
    font-size: 0.55rem !important;
    flex: 1 !important;
    margin-bottom: 0 !important;
  }
  .hero-stats .stat-arrow {
    color: #89F337 !important;
    font-size: 1rem !important;
    font-weight: 700 !important;
  }
}
</style>

<style>
@media (max-width: 768px) {
  .hero-stats {
    display: flex !important;
    flex-direction: column !important;
    background: rgba(137,243,55,0.12) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border: 1px solid rgba(137,243,55,0.3) !important;
    box-shadow: inset 0 1.5px 0 rgba(255,255,255,0.8), inset 0 -1px 0 rgba(137,243,55,0.15), 0 4px 24px rgba(137,243,55,0.1) !important;
    border-radius: 4px !important;
    overflow: hidden !important;
  }
  .hero-stats > div {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 1rem 1.25rem !important;
    border-bottom: 1px solid rgba(137,243,55,0.2) !important;
    background: transparent !important;
    gap: 1rem !important;
  }
  .hero-stats > div:last-child {
    border-bottom: none !important;
  }
  .hero-stats > div > p:last-child {
    font-size: 1.75rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    order: -1 !important;
    min-width: 80px !important;
    color: #263519 !important;
  }
  .hero-stats > div > p:first-child {
    font-size: 0.55rem !important;
    flex: 1 !important;
    margin-bottom: 0 !important;
    color: #82976E !important;
  }
  .hero-stats .stat-arrow {
    color: #89F337 !important;
    font-size: 1rem !important;
    font-weight: 700 !important;
  }
}
</style>
