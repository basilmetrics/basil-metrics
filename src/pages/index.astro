---
import {
<style>
@media (max-width: 768px) {
  .hero-stats { max-width: 100% !important; }
  .hero-stats > div { padding: 0.85rem 1rem !important; }
  .hero-stats > div > p:first-child { font-size: 0.5rem !important; }
  .hero-stats > div > p:last-child { font-size: 1.5rem !important; }
  .services-grid { grid-template-columns: 1fr !important; }
  .results-grid  { grid-template-columns: 1fr !important; }
  .cta-inner     { grid-template-columns: 1fr !important; }
  .how-step      { grid-template-columns: 50px 1fr !important; gap: 1rem !important; }
}
</style>