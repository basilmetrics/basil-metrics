---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('portfolio');
const entries = allEntries
  .filter(e => e.data.published !== false)
  .map(e => ({
    category: e.data.category || '',
    service: e.data.service || 'Ads',
    platform: e.data.platform || '',
    label: e.data.client_name || '',
    result: e.data.result || '',
    img: e.data.cover_image || 'https://images.unsplash.com/photo-1493770348161-369560ae357d?w=800&q=80',
    slug: e.slug,
  }));
---

<BaseLayout
  title="Portfolio — Basil Metrics"
  description="Real campaign results for Bangkok F&B and retail brands."
>
<div style="background:#F6FBF0;min-height:100vh;">
  <div style="max-width:1200px;margin:0 auto;padding:4rem 1.25rem 7rem;">

    <div style="border-bottom:1px solid rgba(38,53,25,0.08);padding-bottom:2.5rem;margin-bottom:3rem;" class="fade-up">
      <span style="font-family:'Sora',sans-serif;font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:#82976E;font-weight:500;display:block;margin-bottom:0.6rem;">Our Work</span>
      <h1 style="font-family:'Sora',sans-serif;font-size:clamp(2rem,4vw,3.25rem);font-weight:800;color:#263519;letter-spacing:-0.02em;">Proof of Work</h1>
      <p style="font-family:'Sora',sans-serif;font-size:0.9rem;color:#82976E;margin-top:0.75rem;max-width:560px;line-height:1.65;">
        Real numbers from real campaigns. Every result is benchmarked against industry averages so you can see exactly how far we outperform the standard.
      </p>
    </div>

    <div style="display:flex;border-bottom:1px solid rgba(38,53,25,0.08);margin-bottom:3rem;overflow-x:auto;" id="filter-tabs">
      {['All','Branding','Ads'].map((t,i) => (
        <button data-filter={t} class="filter-tab"
          style={`font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:500;padding:0.75rem 1.25rem;background:none;border:none;cursor:pointer;margin-bottom:-1px;transition:all 0.18s;border-bottom:2px solid ${i===0?'#263519':'transparent'};color:${i===0?'#263519':'#82976E'};white-space:nowrap;`}
        >{t}</button>
      ))}
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(38,53,25,0.08);" class="port-grid" id="port-grid">
      {entries.map(e => (
        <div class="port-item fade-up" data-svc={e.service} style="background:#FFFFFF;">
          <div style="overflow:hidden;aspect-ratio:16/9;background:#EEF3E8;">
            <img src={e.img} alt={e.label} style="width:100%;height:100%;object-fit:cover;transition:transform 0.55s ease;display:block;" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'" loading="lazy" />
          </div>
          <div style="padding:1.5rem;">
            <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.75rem;flex-wrap:wrap;">
              <span style="font-family:'Sora',sans-serif;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:#82976E;font-weight:600;">{e.category}</span>
              <span style="font-family:'Sora',sans-serif;font-size:0.6rem;background:rgba(137,243,54,0.15);color:#263519;border-radius:99px;padding:0.18rem 0.65rem;font-weight:600;">{e.platform}</span>
            </div>
            <p style="font-family:'Sora',sans-serif;font-size:0.7rem;color:#82976E;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;margin-bottom:0.5rem;">{e.label}</p>
            <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.05rem;color:#263519;line-height:1.35;margin-bottom:1.25rem;">{e.result}</h3>
            <a href={`/portfolio/${e.slug}`} style="font-family:'Sora',sans-serif;font-size:0.8rem;color:#263519;text-decoration:none;border-bottom:1px solid rgba(38,53,25,0.2);padding-bottom:1px;">View Full Case Study →</a>
          </div>
        </div>
      ))}
    </div>

    <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(38,53,25,0.07);">
      <p style="font-family:'Sora',sans-serif;font-size:0.7rem;color:#82976E;line-height:1.8;opacity:0.7;">
        Industry benchmarks sourced from:
        <a href="https://www.wordstream.com/blog/ws/2016/02/29/google-adwords-industry-benchmarks" target="_blank" rel="noopener noreferrer" style="color:#82976E;text-decoration:underline;text-underline-offset:2px;">WordStream Google Ads Benchmarks</a>,
        <a href="https://www.wordstream.com/blog/ws/2021/09/15/facebook-ads-benchmarks" target="_blank" rel="noopener noreferrer" style="color:#82976E;text-decoration:underline;text-underline-offset:2px;">WordStream Meta Ads Benchmarks</a>,
        <a href="https://www.rivaliq.com/blog/tiktok-benchmark-report/" target="_blank" rel="noopener noreferrer" style="color:#82976E;text-decoration:underline;text-underline-offset:2px;">Rival IQ TikTok Benchmark Report</a>.
        All currency conversions at ฿35/USD.
      </p>
    </div>

  </div>
</div>
</BaseLayout>

<style>
  @media (max-width: 768px) { .port-grid { grid-template-columns: 1fr !important; } }
  @media (max-width: 1024px) { .port-grid { grid-template-columns: repeat(2,1fr) !important; } }
</style>

<script>
  const tabs  = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const items = document.querySelectorAll<HTMLElement>('.port-item');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const f = tab.dataset.filter ?? 'All';
      tabs.forEach(t => { t.style.borderBottomColor='transparent'; t.style.color='#82976E'; });
      tab.style.borderBottomColor='#263519'; tab.style.color='#263519';
      items.forEach(item => {
        const s = item.dataset.svc ?? '';
        item.style.display = (f==='All'||s===f||s==='Both') ? '' : 'none';
      });
    });
  });
</script>
